# AsuraCore Environment Variables
# Copy this file to .env and customize values
# NEVER commit .env file to version control

# PostgreSQL Configuration
POSTGRES_PASSWORD=your_secure_password_here_min_12_chars

# InfluxDB Configuration
INFLUXDB_PASSWORD=your_secure_password_here_min_12_chars
INFLUXDB_TOKEN=your_secure_token_here_min_32_chars

# EMQX (MQTT Broker) Configuration
EMQX_DASHBOARD_PASSWORD=your_secure_password_here

# MQTT Backend Credentials
MQTT_PASSWORD=your_secure_mqtt_password_here

# JWT Secret (For authentication tokens)
# IMPORTANT: Use a strong random string in production (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_secure_jwt_secret_min_32_chars

# Device Status Configuration
# How long (ms) without activity before device is marked offline
DEVICE_OFFLINE_TIMEOUT=60000
# How often (ms) to check for offline devices
DEVICE_OFFLINE_CHECK_INTERVAL=30000

# Frontend URLs (adjust to your server domain)
# Local development examples:
FRONTEND_API_URL=http://localhost:4000
FRONTEND_WS_URL=ws://localhost:4000

# Production examples (uncomment for production):
# FRONTEND_API_URL=https://<your-domain>/api/asura
# FRONTEND_WS_URL=wss://<your-domain>/api/asura
