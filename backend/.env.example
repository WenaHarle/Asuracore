# AsuraCore Backend Environment Variables
# Copy this file to .env for local development

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=asuracore
POSTGRES_USER=asuracore
POSTGRES_PASSWORD=asuracore_secret

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=asuracore_influxdb_token_min_32_chars
INFLUXDB_ORG=asuracore
INFLUXDB_BUCKET=telemetry

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=asuracore_backend
MQTT_PASSWORD=backend_mqtt_pass

# JWT
JWT_SECRET=asuracore_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d
